        "5": "五",
      },
      "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": []
      }
    },

    "hyprland/workspaces#right": {
      "on-click": "activate",
      "format": "{icon}",
